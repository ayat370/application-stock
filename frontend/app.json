{
  "expo": {
    "name": "StockApp",
    "slug": "stock-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1A56DB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stockapp.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A56DB"
      },
      "package": "com.stockapp.mobile",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      [
        "expo-camera",
        { "cameraPermission": "StockApp utilise la caméra pour scanner les codes-barres." }
      ]
    ]
  }
}
